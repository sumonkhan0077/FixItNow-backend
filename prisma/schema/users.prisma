model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  phone      String?
  role       Role
  status     UserStatus  @default(ACTIVE)

  image       String?
  address     String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
 

  @@map("users")
}